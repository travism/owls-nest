# ----- Core -----
NODE_ENV=development
PORT=3000

# Postgres runs on the host (per ARCHITECTURE.md §11.1)
# In Compose, api/build-worker reach it via host.docker.internal
DATABASE_URL=postgresql://owlsnest:owlsnest@host.docker.internal:5432/owlsnest

# Redis runs as a Compose service
REDIS_HOST=redis
REDIS_PORT=6379

# ----- Secrets (required in production) -----
# Generate with: openssl rand -hex 32
ADMIN_TOTP_KEY=
SESSION_SECRET=
CLEANER_TOKEN_SECRET=

# ----- Stripe -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Twilio -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----- Email (M9 / D-021) -----
# Provider selection: mailhog (dev default) | mailersend (prod) | fake (tests).
# In dev, MailHog runs as a Compose service and exposes a UI at
# http://localhost:8025. Production must set EMAIL_PROVIDER=mailersend.
EMAIL_PROVIDER=mailhog
EMAIL_FROM="The Owl's Nest <noreply@owlsnest.local>"
MAILHOG_HOST=mailhog
MAILHOG_PORT=1025
ADMIN_NOTIFICATION_EMAIL=admin@owlsnest.local

# ----- MailerSend (production only) -----
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=

# ----- PriceLabs (Customer API) -----
PRICELABS_API_KEY=
PRICELABS_LISTING_ID=

# ----- Internal URLs -----
# Used by web (build-time fetches) to reach api inside the Compose network
INTERNAL_API_URL=http://api:3000
