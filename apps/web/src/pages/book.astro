---
import Site from '../layouts/Site.astro';
import { BookingCalendar } from '../components/BookingCalendar';
import '../styles/booking-calendar.css';
---

<Site
  title="Book your stay"
  description="Check availability, see pricing, and start your reservation for The Owl's Nest."
>
  <section class="section">
    <div class="container">
      <h1>Book your stay</h1>
      <p style="max-width: 60ch;">
        Pick your check-in and check-out dates below. We'll show pricing
        including Oregon and Redmond lodging tax, then hand you a quick form
        to send your inquiry — booking is by request and we'll review your
        dates personally.
      </p>

      <BookingCalendar client:visible />
    </div>
  </section>
</Site>
