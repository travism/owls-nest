---
import Site from '../../layouts/Site.astro';
import { InquiryForm } from '../../components/InquiryForm';
import '../../styles/inquiry-form.css';
---

<Site
  title="Make a booking request"
  description="Request your selected dates at The Owl's Nest. We'll review and respond by email."
>
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <h1>Make a booking request</h1>
      <p>
        We'll review your dates and reply by email — usually within a few hours.
        No payment is taken at this step; if we approve, we'll send a Stripe
        payment link separately.
      </p>

      <InquiryForm client:load />
    </div>
  </section>
</Site>
