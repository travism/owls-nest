{
  "name": "owlsnest",
  "version": "0.1.0",
  "private": true,
  "description": "The Owl's Nest platform — guest site, booking engine, and admin dashboard",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter='./apps/**' --filter='./packages/**' run build",
    "dev": "pnpm -r --parallel --filter='./apps/api' --filter='./apps/web' --filter='./apps/admin' run dev",
    "dev:build-worker": "pnpm --filter @owlsnest/build-worker run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r --filter='@owlsnest/shared' --filter='@owlsnest/admin' --filter='@owlsnest/web' --filter='@owlsnest/api' run test",
    "test:e2e": "pnpm --filter @owlsnest/api run test:e2e",
    "test:all": "pnpm run test && pnpm run test:e2e",
    "prisma:generate": "pnpm --filter @owlsnest/prisma run generate",
    "prisma:migrate": "pnpm --filter @owlsnest/prisma run migrate:dev",
    "prisma:seed": "pnpm --filter @owlsnest/prisma run seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "husky": "^9.1.7",
    "typescript": "^5.5.4"
  }
}
