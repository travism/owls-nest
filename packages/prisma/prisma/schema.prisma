// The Owl's Nest — Prisma schema
// Mirrors ARCHITECTURE.md §4.2 entity list and field shapes from PRD §12,
// loging-tax-plan.md §5.1, and calendar-sync-plan.md §4.2.
//
// Convention: TypeScript field names are camelCase; database columns are
// snake_case via @map. Table names are snake_case via @@map.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// PROPERTY
// =====================================================================

model Property {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  addressLine1        String   @map("address_line_1")
  city                String
  state               String   @db.VarChar(2)
  postalCode          String   @map("postal_code")
  checkInTime         String   @db.VarChar(8) @map("check_in_time")
  checkOutTime        String   @db.VarChar(8) @map("check_out_time")
  maxGuests           Int      @default(4) @map("max_guests")
  baseNightlyRate     Decimal  @db.Decimal(10, 2) @map("base_nightly_rate")
  cleaningFee         Decimal  @db.Decimal(10, 2) @map("cleaning_fee")
  minStay             Int      @default(2) @map("min_stay")
  cancellationPolicy  Json     @map("cancellation_policy")

  taxJurisdictions    TaxJurisdiction[]
  bookings            Booking[]
  blockedDates        BlockedDate[]
  pricingOverrides    PricingOverride[]
  pricingCacheEntries PricingCacheEntry[]
  calendarSyncs       CalendarSync[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("property")
}

// =====================================================================
// TAX (per loging-tax-plan.md §5.1, Option B)
// =====================================================================

model TaxJurisdiction {
  id                    String    @id @default(uuid()) @db.Uuid
  propertyId            String    @db.Uuid @map("property_id")
  property              Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  jurisdictionName      String    @map("jurisdiction_name")
  jurisdictionLevel     String    @map("jurisdiction_level")
  taxRate               Decimal   @db.Decimal(5, 4) @map("tax_rate")
  adminFeeRate          Decimal?  @db.Decimal(5, 4) @map("admin_fee_rate")
  filingFrequency       String    @map("filing_frequency")
  filingAuthority       String?   @map("filing_authority")
  filingPortalUrl       String?   @map("filing_portal_url")
  exemptThresholdNights Int       @default(30) @map("exempt_threshold_nights")
  effectiveFrom         DateTime  @default(now()) @db.Date @map("effective_from")
  effectiveTo           DateTime? @db.Date @map("effective_to")
  verifiedAt            DateTime  @default(now()) @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([propertyId, effectiveTo])
  @@map("tax_jurisdiction")
}

// =====================================================================
// AUTH (admin)
// =====================================================================

model AdminUser {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  passwordHash        String    @map("password_hash")
  totpSecretEncrypted String?   @map("totp_secret_encrypted")
  totpEnrolledAt      DateTime? @map("totp_enrolled_at")
  recoveryCodesHashed String[]  @default([]) @map("recovery_codes_hashed")
  failedAttempts      Int       @default(0) @map("failed_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")

  auditLogEntries AuditLogEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_user")
}

// =====================================================================
// GUEST
// =====================================================================

model Guest {
  id    String  @id @default(uuid()) @db.Uuid
  name  String
  email String  @unique
  phone String?

  bookings   Booking[]
  magicLinks MagicLinkToken[]
  messages   Message[]

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("guest")
}

model MagicLinkToken {
  id          String    @id @default(uuid()) @db.Uuid
  guestId     String    @db.Uuid @map("guest_id")
  guest       Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  ipRequested String?   @map("ip_requested")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([guestId])
  @@index([expiresAt])
  @@map("magic_link_token")
}

// =====================================================================
// INQUIRY
// =====================================================================

model Inquiry {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  email              String
  phone              String?
  checkIn            DateTime @db.Date @map("check_in")
  checkOut           DateTime @db.Date @map("check_out")
  message            String?
  status             String   @default("new")
  convertedBookingId String?  @db.Uuid @map("converted_booking_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("inquiry")
}

// =====================================================================
// BOOKING
// =====================================================================

model Booking {
  id          String    @id @default(uuid()) @db.Uuid
  propertyId  String    @db.Uuid @map("property_id")
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  guestId     String?   @db.Uuid @map("guest_id")
  guest       Guest?    @relation(fields: [guestId], references: [id], onDelete: SetNull)

  checkIn   DateTime @db.Date @map("check_in")
  checkOut  DateTime @db.Date @map("check_out")
  numGuests Int      @map("num_guests")

  status String
  source String @default("direct")

  // Pricing
  nightlyRate         Decimal @db.Decimal(10, 2) @map("nightly_rate")
  numNights           Int     @map("num_nights")
  subtotal            Decimal @db.Decimal(10, 2)
  cleaningFeeInternal Decimal @db.Decimal(10, 2) @default(0) @map("cleaning_fee_internal")

  // Tax (per loging-tax-plan.md §5.1)
  stateTltAmount        Decimal @db.Decimal(10, 2) @default(0) @map("state_tlt_amount")
  cityTltAmount         Decimal @db.Decimal(10, 2) @default(0) @map("city_tlt_amount")
  totalTaxAmount        Decimal @db.Decimal(10, 2) @default(0) @map("total_tax_amount")
  stateAdminFeeRetained Decimal @db.Decimal(10, 2) @default(0) @map("state_admin_fee_retained")
  taxExempt             Boolean @default(false) @map("tax_exempt")
  taxExemptReason       String? @map("tax_exempt_reason")
  otaRemittedState      Boolean @default(false) @map("ota_remitted_state")
  otaRemittedCity       Boolean @default(false) @map("ota_remitted_city")

  // Payment — see BookingCharge for individual transactions.
  // stripeCustomerId stays here because it's reusable across charges
  // (initial deposit + extension charges + damage charges, etc.).
  stripeCustomerId String? @map("stripe_customer_id")
  netRevenue       Decimal @db.Decimal(10, 2) @default(0) @map("net_revenue")

  // Cancellation
  cancellationTierApplied String?   @map("cancellation_tier_applied")
  refundAmount            Decimal?  @db.Decimal(10, 2) @map("refund_amount")
  cancelledAt             DateTime? @map("cancelled_at")

  charges             BookingCharge[]
  messages            Message[]
  turnoverAssignments TurnoverAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, checkIn])
  @@index([source])
  @@index([guestId])
  @@map("booking")
}

// Per-booking payment transactions. A booking can have many charges:
//   - 'initial'   — the original payment when booking was confirmed (M7)
//   - 'extension' — additional nights added mid- or pre-stay (M8)
//   - 'damage'    — post-stay damage assessed against card on file (M8)
//   - 'incidental'— late check-out, accidental pet, etc. (M8)
// Each charge maps to one Stripe PaymentIntent (and optionally one
// Checkout Session if we sent a hosted payment link).
//
// Per-charge stripeFee tracking lets the financials view (M4.2) sum
// fees accurately across multiple charges per booking.
model BookingCharge {
  id              String   @id @default(uuid()) @db.Uuid
  bookingId       String   @db.Uuid @map("booking_id")
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind            String   // 'initial' | 'extension' | 'damage' | 'incidental'
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("usd")
  description     String?
  status          String   @default("pending") // 'pending' | 'sent' | 'succeeded' | 'failed' | 'refunded'

  stripePaymentIntentId    String?   @unique @map("stripe_payment_intent_id")
  stripeCheckoutSessionId  String?   @unique @map("stripe_checkout_session_id")
  stripeFee                Decimal   @db.Decimal(10, 2) @default(0) @map("stripe_fee")
  refundedAmount           Decimal   @db.Decimal(10, 2) @default(0) @map("refunded_amount")

  paidAt          DateTime? @map("paid_at")
  refundedAt      DateTime? @map("refunded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([bookingId, kind])
  @@index([status, createdAt])
  @@map("booking_charge")
}

// =====================================================================
// CLEANER
// =====================================================================

model Cleaner {
  id           String  @id @default(uuid()) @db.Uuid
  name         String
  phone        String
  priorityRank Int     @map("priority_rank")
  active       Boolean @default(true)

  portalTokens        CleanerToken[]
  requestTokens       CleanerRequestToken[]
  turnoverAssignments TurnoverAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([priorityRank])
  @@index([active, priorityRank])
  @@map("cleaner")
}

model CleanerToken {
  id        String    @id @default(uuid()) @db.Uuid
  cleanerId String    @db.Uuid @map("cleaner_id")
  cleaner   Cleaner   @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([cleanerId])
  @@map("cleaner_token")
}

model CleanerRequestToken {
  id           String             @id @default(uuid()) @db.Uuid
  cleanerId    String             @db.Uuid @map("cleaner_id")
  cleaner      Cleaner            @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  assignmentId String             @db.Uuid @map("assignment_id")
  assignment   TurnoverAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  action       String
  expiresAt    DateTime           @map("expires_at")
  consumedAt   DateTime?          @map("consumed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([cleanerId])
  @@index([assignmentId])
  @@index([expiresAt])
  @@map("cleaner_request_token")
}

model TurnoverAssignment {
  id                  String    @id @default(uuid()) @db.Uuid
  bookingId           String    @db.Uuid @map("booking_id")
  booking             Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cleanerId           String?   @db.Uuid @map("cleaner_id")
  cleaner             Cleaner?  @relation(fields: [cleanerId], references: [id], onDelete: SetNull)

  date                DateTime  @db.Date
  checkOutTime        String    @db.VarChar(8) @map("check_out_time")
  checkInTime         String    @db.VarChar(8) @map("check_in_time")
  status              String    @default("unassigned")
  specialInstructions String?   @map("special_instructions")
  requestHistory      Json      @default("[]") @map("request_history")
  completedAt         DateTime? @map("completed_at")

  requestTokens CleanerRequestToken[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@index([status])
  @@map("turnover_assignment")
}

// =====================================================================
// MESSAGING
// =====================================================================

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  guestId   String?  @db.Uuid @map("guest_id")
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  bookingId String?  @db.Uuid @map("booking_id")
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  direction  String
  body       String
  templateId String?          @db.Uuid @map("template_id")
  template   MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  twilioSid   String?   @unique @map("twilio_sid")
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([guestId, createdAt])
  @@index([bookingId])
  @@map("message")
}

model MessageTemplate {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  type       String
  body       String
  isDefault  Boolean   @default(false) @map("is_default")
  archivedAt DateTime? @map("archived_at")

  messages Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("message_template")
}

// =====================================================================
// CONTENT
// =====================================================================

model BlogPost {
  id                String    @id @default(uuid()) @db.Uuid
  title             String
  slug              String    @unique
  body              String
  excerpt           String?
  featuredImagePath String?   @map("featured_image_path")
  status            String    @default("draft")
  publishedAt       DateTime? @map("published_at")
  seoTitle          String?   @map("seo_title")
  seoDescription    String?   @map("seo_description")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@map("blog_post")
}

// =====================================================================
// REVIEW
// =====================================================================

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  guestName  String   @map("guest_name")
  platform   String
  rating     Int
  body       String
  bookingId  String?  @db.Uuid @map("booking_id")
  visible    Boolean  @default(false)
  reviewDate DateTime @db.Date @map("review_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([visible, reviewDate])
  @@map("review")
}

// =====================================================================
// CALENDAR (per calendar-sync-plan.md §4.2)
// =====================================================================

model CalendarSync {
  id                  String    @id @default(uuid()) @db.Uuid
  propertyId          String    @db.Uuid @map("property_id")
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  platform            String
  icalImportUrl       String    @map("ical_import_url")
  lastSyncedAt        DateTime? @map("last_synced_at")
  lastSyncStatus      String    @default("pending") @map("last_sync_status")
  lastSyncError       String?   @map("last_sync_error")
  lastSyncEventCount  Int       @default(0) @map("last_sync_event_count")
  syncIntervalMinutes Int       @default(30) @map("sync_interval_minutes")
  active              Boolean   @default(true)

  blockedDates BlockedDate[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("calendar_sync")
}

model BlockedDate {
  id             String        @id @default(uuid()) @db.Uuid
  propertyId     String        @db.Uuid @map("property_id")
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  startDate      DateTime      @db.Date @map("start_date")
  endDate        DateTime      @db.Date @map("end_date")
  reason         String
  sourcePlatform String?       @map("source_platform")
  sourceEventUid String?       @map("source_event_uid")
  sourceSummary  String?       @map("source_summary")
  calendarSyncId String?       @db.Uuid @map("calendar_sync_id")
  calendarSync   CalendarSync? @relation(fields: [calendarSyncId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sourceEventUid, calendarSyncId])
  @@index([startDate, endDate])
  @@map("blocked_date")
}

// =====================================================================
// PRICING
// =====================================================================

model PricingOverride {
  id              String   @id @default(uuid()) @db.Uuid
  propertyId      String   @db.Uuid @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  nightlyRate     Decimal  @db.Decimal(10, 2) @map("nightly_rate")
  minStayOverride Int?     @map("min_stay_override")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([propertyId, date])
  @@map("pricing_override")
}

model PricingCacheEntry {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String   @db.Uuid @map("property_id")
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  nightlyRate Decimal  @db.Decimal(10, 2) @map("nightly_rate")
  minStay     Int      @default(1) @map("min_stay")
  source      String   @default("pricelabs")
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@unique([propertyId, date])
  @@index([fetchedAt])
  @@map("pricing_cache_entry")
}

// =====================================================================
// PROMO (deferred — schema only)
// =====================================================================

model PromoCode {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique
  discountType  String    @map("discount_type")
  discountValue Decimal   @db.Decimal(10, 2) @map("discount_value")
  validFrom     DateTime  @db.Date @map("valid_from")
  validTo       DateTime? @db.Date @map("valid_to")
  maxUses       Int?      @map("max_uses")
  currentUses   Int       @default(0) @map("current_uses")
  active        Boolean   @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("promo_code")
}

// =====================================================================
// AUDIT (per ARCHITECTURE.md §12.4)
// =====================================================================

model AuditLogEntry {
  id          String     @id @default(uuid()) @db.Uuid
  adminUserId String?    @db.Uuid @map("admin_user_id")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String?    @map("target_type")
  targetId    String?    @map("target_id")
  before      Json?
  after       Json?
  ipAddress   String?    @map("ip_address")
  userAgent   String?    @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_log_entry")
}

// =====================================================================
// WEBHOOK IDEMPOTENCY (per ARCHITECTURE.md §13.2)
// =====================================================================

model WebhookEvent {
  id          String    @id
  provider    String
  eventType   String?   @map("event_type")
  payload     Json?
  processedAt DateTime? @map("processed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([provider, createdAt])
  @@map("webhook_event")
}

// =====================================================================
// OUTBOX (per ARCHITECTURE.md §7.3)
// =====================================================================

model Outbox {
  id             String    @id @default(uuid()) @db.Uuid
  jobName        String    @map("job_name")
  payload        Json
  idempotencyKey String?   @unique @map("idempotency_key")
  enqueuedAt     DateTime? @map("enqueued_at")
  failedAt       DateTime? @map("failed_at")
  failureReason  String?   @map("failure_reason")
  attempts       Int       @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([enqueuedAt])
  @@map("outbox")
}
